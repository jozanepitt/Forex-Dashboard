# Copy this file to .env and fill in your real Twelve Data API keys.
# Get free keys at https://twelvedata.com — free plan: 800 credits/day/key.
# Add as many KEY_N / KEY_N_NAME pairs as you have keys (stops at first gap).

TWELVEDATA_KEY_1_NAME=my_key_1
TWELVEDATA_KEY_1=your_twelvedata_api_key_here

TWELVEDATA_KEY_2_NAME=my_key_2
TWELVEDATA_KEY_2=your_second_api_key_here

# TWELVEDATA_KEY_3_NAME=my_key_3
# TWELVEDATA_KEY_3=your_third_api_key_here

# TWELVEDATA_KEY_4_NAME=my_key_4
# TWELVEDATA_KEY_4=your_fourth_api_key_here

# Optional: Stooq CSV fallback (captcha-gated — see README)
# STOOQ_APIKEY=your_stooq_api_key_here

SERVICE_PORT=3002
SERVICE_HOST=127.0.0.1
DAILY_CREDIT_LIMIT=800
CREDIT_SAFETY_MARGIN=50
